# ============================================================
# T-Invest Trader -- Runtime Configuration
# Copy to .env and fill in real values before deployment.
# ============================================================

# -- Environment --
TINVEST_ENVIRONMENT=sandbox

# -- Broker --
TINVEST_TOKEN=your-tbank-api-token-here
TINVEST_ACCOUNT_ID=your-account-id-here
TINVEST_SANDBOX=true

# -- Database --
# DSN must match docker-compose postgres service credentials.
TINVEST_POSTGRES_DSN=postgresql://tinvest:tinvest_local@postgres:5432/tinvest
POSTGRES_PASSWORD=tinvest_local

# -- Grafana --
# Change these before exposing Grafana publicly.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -- Instruments --
TINVEST_TRACKED_INSTRUMENTS=
TINVEST_ENABLED_INSTRUMENTS=

# -- Sentiment --
TINVEST_SENTIMENT_ENABLED=false
TINVEST_SENTIMENT_CHANNELS=
TINVEST_SENTIMENT_TRACKED_TICKERS=
TINVEST_SENTIMENT_MODEL_NAME=stub
TINVEST_SENTIMENT_SOURCE_BACKEND=stub

# -- Observation --
TINVEST_OBSERVATION_ENABLED=false
TINVEST_OBSERVATION_WINDOWS=5m,15m,1h
TINVEST_OBSERVATION_PERSIST_DERIVED=true
TINVEST_OBSERVATION_TRACKED_TICKERS=

# -- Logging --
TINVEST_LOG_LEVEL=INFO
TINVEST_LOG_JSON=true

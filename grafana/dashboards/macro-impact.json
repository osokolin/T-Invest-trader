        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT sp.id) AS signals_with_macro\nFROM signal_predictions sp\nJOIN macro_messages mm\n    ON mm.created_at BETWEEN sp.created_at - interval '60 minutes'\n                         AND sp.created_at\nWHERE sp.resolved_at IS NOT NULL;",
          "refId": "A"
        }
      ],
      "title": "Signals Linked to Macro (resolved)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres" },

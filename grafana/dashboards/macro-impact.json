          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT t.tag) AS active_tags\nFROM macro_messages mm\nCROSS JOIN LATERAL unnest(mm.tags) AS t(tag)\nWHERE mm.created_at >= now() - interval '7 days';",
          "refId": "A"
        }
      ],
      "title": "Active Tags (7d)",

      "id": 101,
      "title": "Performance by Tag",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "win_rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_return" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "delta_wr" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": -0.03 }, { "color": "text", "value": 0 }, { "color": "green", "value": 0.03 }] } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "avg_return", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH baseline AS (\n    SELECT\n        avg(CASE WHEN outcome_label = 'win' THEN 1.0 ELSE 0.0 END) AS base_wr\n    FROM signal_predictions\n    WHERE resolved_at IS NOT NULL\n)\nSELECT\n    t.tag,\n    count(DISTINCT sp.id) AS total_signals,\n    count(DISTINCT sp.id)\n        FILTER (WHERE sp.resolved_at IS NOT NULL) AS resolved,\n    count(DISTINCT sp.id)\n        FILTER (WHERE sp.outcome_label = 'win') AS wins,\n    count(DISTINCT sp.id)\n        FILTER (WHERE sp.outcome_label = 'loss') AS losses,\n    round(avg(CASE WHEN sp.outcome_label = 'win' THEN 1.0 ELSE 0.0 END)\n        FILTER (WHERE sp.resolved_at IS NOT NULL)::numeric, 3) AS win_rate,\n    round(avg(sp.return_pct)\n        FILTER (WHERE sp.resolved_at IS NOT NULL)::numeric, 5) AS avg_return,\n    round((avg(CASE WHEN sp.outcome_label = 'win' THEN 1.0 ELSE 0.0 END)\n        FILTER (WHERE sp.resolved_at IS NOT NULL) - b.base_wr)::numeric, 3) AS delta_wr\nFROM signal_predictions sp\nJOIN macro_messages mm\n    ON mm.created_at BETWEEN sp.created_at - interval '60 minutes'\n                         AND sp.created_at\nCROSS JOIN LATERAL unnest(mm.tags) AS t(tag)\nCROSS JOIN baseline b\nWHERE sp.resolved_at IS NOT NULL\nGROUP BY t.tag, b.base_wr\nHAVING count(DISTINCT sp.id)\n    FILTER (WHERE sp.resolved_at IS NOT NULL) >= 3\nORDER BY avg_return DESC NULLS LAST;",
          "refId": "A"
        }
      ],
      "title": "Tag Impact (vs baseline)",
      "type": "table"
    },

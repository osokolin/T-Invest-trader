          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(created_at, '1d'), COALESCE(pipeline_stage, 'unknown') AS metric, count(*)::double precision AS value FROM signal_predictions WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Signals by Stage Over Time",
      "type": "timeseries"
    }
